# ─────────────────────────────────────────────────────────────────
# Speed Dating Analysis · Environment Variables Template
# ─────────────────────────────────────────────────────────────────
# Copy this file to `.env` (gitignored) and fill in your values.
#   cp .env.example .env
#
# All variables are validated by `src/speed_dating/config.py` at
# startup via pydantic-settings; missing or malformed values raise
# a `ValidationError` immediately rather than failing mid-pipeline.
# ─────────────────────────────────────────────────────────────────

# Path to the raw Speed Dating CSV (Fisman et al. 2006).
# Use a path RELATIVE to the project root, or an absolute path.
SD_DATA_RAW=data/Speed+Dating+Data.csv

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
SD_LOG_LEVEL=INFO

# Random seed for all stochastic operations (XGBoost, sampling).
SD_RANDOM_SEED=42

# Number of CPU cores for parallel ops (-1 = all).
SD_N_JOBS=-1
